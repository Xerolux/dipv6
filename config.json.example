{
  "ispconfig_url": "https://your-ispconfig-server.com:8080",
  "ispconfig_username": "admin",
  "ispconfig_password": "your-ispconfig-password",
  "ispconfig_client_id": "0",
  "domains": {
    "home.blueml.one": {
      "ipv4_enabled": false,
      "ipv6_enabled": true,
      "use_calculated_ipv6": false,
      "dynamic_dns": {}
    },
    "custom.blueml.one": {
      "ipv4_enabled": true,
      "ipv6_enabled": true,
      "use_calculated_ipv6": false,
      "dynamic_dns": {
        "service": "custom",
        "hostname": "custom.blueml.one",
        "username": "api-user",
        "password": "api-password-or-token",
        "server": "https://provider.example.com/nic/update"
      }
    }
  },
  "auth_tokens": {
    "your-secret-token-here": {
      "name": "UniFi Token",
      "device_name": "UniFi-Dream-Machine"
    }
  },
  "ssl_cert": "/etc/letsencrypt/live/dyn.blueml.one/fullchain.pem",
  "ssl_key": "/etc/letsencrypt/live/dyn.blueml.one/privkey.pem",
  "port": 5000,
  "host": "127.0.0.1",
  "nginx_update_enabled": false,

  "_legacy_note": "The single ipv6_domain/ipv4_domain keys below are still supported as a fallback if 'domains' is empty.",
  "ipv6_domain": "home.blueml.one",
  "ipv4_domain": "home-ipv4.blueml.one"
}
